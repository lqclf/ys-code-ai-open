<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eric.module.system.mapper.SysRoleMapper">
<!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.eric.module.system.entity.SysRole">
    	<id column="id" property="id"/>
        <result column="code" property="code"/>
        <result column="name" property="name"/>
        <result column="remark" property="remark"/>
        <result column="seq" property="seq"/>
        <result column="status" property="status"/>
        <result column="is_delete" property="isDelete"/>
        <result column="create_time" property="createTime"/>
        <result column="create_by" property="createBy"/>
        <result column="create_name" property="createName"/>
    </resultMap>
    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
		id, code, name, remark, seq, status, is_delete, create_time, create_by, create_name
    </sql>
    <!-- 获取角色菜单id -->
    <select id="getRoleMenusIds" resultType="java.lang.String">
        select m.id from sys_role_menu rm left join sys_menu m on rm.menu_id = m.id where rm.role_id = #{roleId}
    </select>
    <!-- 批量删除角色菜单 -->
    <delete id="deleteMenuByRoleId">
        delete from sys_role_menu where role_id in
        <foreach collection="ids" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
    </delete>
    <!-- 批量添加角色菜单 -->
    <insert id="insertRoleMenus">
        insert into sys_role_menu(role_id, menu_id) values
        <foreach collection="menuIds" item="item" separator=",">
            (#{id}, #{item})
        </foreach>
    </insert>
</mapper>