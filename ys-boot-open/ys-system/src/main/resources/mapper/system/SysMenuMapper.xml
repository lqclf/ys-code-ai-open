<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eric.module.system.mapper.SysMenuMapper">
<!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.eric.module.system.entity.SysMenu">
    	<id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="pid" property="pid"/>
        <result column="name" property="name"/>
        <result column="component" property="component"/>
        <result column="redirect" property="redirect"/>
        <result column="path" property="path"/>
        <result column="permission" property="permission"/>
        <result column="icon" property="icon"/>
        <result column="link" property="link"/>
        <result column="seq" property="seq"/>
        <result column="type" property="type"/>
        <result column="is_link" property="isLink"/>
        <result column="is_hide" property="isHide"/>
        <result column="is_cache" property="isCache"/>
        <result column="is_affix" property="isAffix"/>
        <result column="is_delete" property="isDelete"/>
        <result column="create_time" property="createTime"/>
        <result column="create_by" property="createBy"/>
        <result column="create_name" property="createName"/>
    </resultMap>
    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
		id, title, pid, name, component, redirect, path, permission, icon, link, seq, type, is_link, is_hide, is_cache, is_affix, is_delete, create_time, create_by, create_name
    </sql>
    
    <!-- 根据用户ID获取菜单列表 -->
    <select id="getUserMenuList" resultType="com.eric.module.system.entity.SysMenu" parameterType="java.lang.String">
        SELECT DISTINCT m.*
        FROM sys_menu m
                 LEFT JOIN sys_role_menu rm ON m.id = rm.menu_id
                 LEFT JOIN sys_user_role ur ON rm.role_id = ur.role_id
        WHERE ur.user_id = #{userId}
          AND m.is_delete = 1 AND m.type in(1, 2)
        ORDER BY m.seq
    </select>

</mapper>